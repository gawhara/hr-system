APP_NAME="SMARS HR"
APP_ENV=local
APP_KEY=
# PRODUCTION/BRANCH DEPLOYMENT: set APP_DEBUG=false — debug pages leak config,
# paths and query data.
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=hr_system
# PRODUCTION/BRANCH DEPLOYMENT: create a dedicated MySQL user with a strong
# password — never run on root with an empty password outside local dev.
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
# PRODUCTION/BRANCH DEPLOYMENT: set SESSION_ENCRYPT=true.
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Seeded demo accounts (admin@hr.local, hr1-4@hr.local) use this password.
# PRODUCTION/BRANCH DEPLOYMENT: set a strong value BEFORE running db:seed.
HR_SEED_PASSWORD=password

# Document expiry alerts: mail channel is opt-in per deployment.
HR_EXPIRY_ALERT_MAIL=false
HR_EXPIRY_ALERT_NOTIFY_EMPLOYEE=true

# Offline sync (Strategy A): standalone | branch | central.
# PRODUCTION: sync API must only be exposed over HTTPS; use a long random
# HR_SYNC_TOKEN and rotate it when a branch machine is decommissioned.
HR_SYNC_ROLE=standalone
HR_SYNC_CENTRAL_URL=
HR_SYNC_TOKEN=
HR_SYNC_DEVICE_NAME=
